# Client-side analytics (injected into web/site at build time)
# POSTHOG_PROJECT_TOKEN is the PUBLIC project API key (phc_...) — the build
# refuses to run if this is not a phc_ key, so private keys can never leak.
POSTHOG_PROJECT_TOKEN=phc_...
# Capture/ingestion host (browser SDK + /api/collect relay)
POSTHOG_API_HOST=https://us.i.posthog.com
# Private/app API host (ingest + taxonomy — reads via personal key)
POSTHOG_APP_HOST=https://us.posthog.com

# Server-side ingest + taxonomy (engine/loop.mjs ingest|taxonomy)
# POSTHOG_PERSONAL_API_KEY is your private phx_... key — NEVER commit it.
# Must be minted in the PostHog org that owns POSTHOG_PROJECT_ID below.
POSTHOG_PERSONAL_API_KEY=phx_...
POSTHOG_PROJECT_ID=521236

# Optional: make the site beacon events to /api/collect as a backup
# LOOP_SINK_URL=/api/collect

# Optional: Hotjar heatmaps/funnels
# HOTJAR_SITE_ID=...
# HOTJAR_SNIPPET_VERSION=6

# Site domain used for canonical/OG URLs
LOOP_SITE_DOMAIN=viralfreegames.com
