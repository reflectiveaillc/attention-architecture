# Vercel / external service env vars for the Tilt live deploy.
# Set these in the Vercel dashboard (Project Settings → Environment Variables)
# or via `npx vercel env add`.

# Hotjar funnel tracking. Get the Site ID from https://insights.hotjar.com/sites
HOTJAR_SITE_ID=1234567
HOTJAR_SNIPPET_VERSION=6

# Optional: override dashboard password hash (SHA-256 of the password).
# The hash is baked into web/site/tilt-dashboard.html at deploy/regeneration time.
# DASHBOARD_PASSWORD_HASH=8d0d58e645c8bf5a9a1c959f006f4a853edb6b38ddc537eb3642230690005fdf

# Optional: Cloudflare R2 credentials for external clip hosting (recommended over
# committing 1.2GB of MP4s to git). Once set, run `node engine/deploy-clips-r2.mjs`.
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=tilt-clips
# R2_PUBLIC_URL=https://clips.tilt-games.vercel.app or https://pub-<hash>.r2.dev
